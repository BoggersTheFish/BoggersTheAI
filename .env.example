# Copy this file to .env and fill in values locally.
# Do not commit your real .env file.

# X/Twitter adapter (optional)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Optional remote inference fallback
INFERENCE_API_KEY=
INFERENCE_BASE_URL=

# FastAPI dashboard (optional)
# If BOGGERS_DASHBOARD_TOKEN is set, /status, /graph, /metrics, /traces require:
#   Authorization: Bearer <token>
# Leave empty for local-only open access.
BOGGERS_DASHBOARD_TOKEN=
BOGGERS_DASHBOARD_HOST=0.0.0.0
BOGGERS_DASHBOARD_PORT=8000
